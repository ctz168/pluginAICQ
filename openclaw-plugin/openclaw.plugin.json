{
  "kind": "channel",
  "id": "aicq-chat",
  "name": "AICQ Encrypted Chat",
  "version": "3.0.0",
  "description": "End-to-end encrypted chat channel via AICQ protocol — in-process Channel plugin",
  "entry": "index.js",
  "activation": {
    "onStartup": true
  },
  "enabledByDefault": true,
  "channels": ["aicq-chat"],
  "channelConfigs": {
    "aicq-chat": {
      "accounts": {
        "type": "object",
        "properties": {
          "accountId": {
            "type": "string",
            "description": "绑定到 OpenClaw 智能体的账户 ID",
            "default": "{{agent.id}}"
          },
          "autoAcceptFriends": {
            "type": "boolean",
            "default": true,
            "description": "是否自动接受好友请求"
          }
        },
        "required": ["accountId"]
      }
    }
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "serverUrl": {
        "type": "string",
        "description": "AICQ 服务器地址",
        "default": "https://aicq.online"
      },
      "autoAcceptFriends": {
        "type": "boolean",
        "description": "自动接受好友请求",
        "default": true
      },
      "debug": {
        "type": "boolean",
        "description": "Enable verbose debug logging",
        "default": false
      }
    }
  },
  "uiHints": {
    "serverUrl": {
      "label": "AICQ Server URL",
      "help": "The AICQ signaling server URL for WebSocket connections."
    },
    "autoAcceptFriends": {
      "label": "Auto Accept Friends",
      "help": "Automatically accept incoming friend requests."
    },
    "debug": {
      "label": "Debug Mode",
      "help": "Enable verbose logging for troubleshooting.",
      "advanced": true
    }
  },
  "contracts": {
    "tools": [
      "chat-friend",
      "chat-send",
      "chat-export-key"
    ],
    "gateway": [
      "aicq.status",
      "aicq.friends.list",
      "aicq.friends.add",
      "aicq.friends.remove",
      "aicq.friends.requests",
      "aicq.friends.acceptRequest",
      "aicq.friends.rejectRequest",
      "aicq.sessions.list",
      "aicq.identity.info",
      "aicq.agent.create",
      "aicq.agent.delete",
      "aicq.chat.history",
      "aicq.chat.send",
      "aicq.chat.delete",
      "aicq.chat.streamChunk",
      "aicq.chat.streamEnd",
      "aicq.groups.list",
      "aicq.groups.create",
      "aicq.groups.join",
      "aicq.groups.messages",
      "aicq.groups.silent"
    ]
  },
  "runtime": "node",
  "requires": {
    "node": ">=18.0.0",
    "packages": [
      "sql.js",
      "tweetnacl",
      "tweetnacl-util",
      "ws",
      "qrcode",
      "express"
    ]
  }
}
