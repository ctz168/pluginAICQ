{
  "id": "aicq-chat",
  "name": "AICQ Encrypted Chat",
  "version": "2.6.6",
  "description": "End-to-end encrypted chat plugin for OpenClaw agents — Node.js implementation with full UI",
  "entry": "index.js",
  "activation": {
    "onStartup": true
  },
  "enabledByDefault": true,
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "enabled": {
        "type": "boolean",
        "description": "Enable the AICQ chat plugin (default: true).",
        "default": true
      },
      "port": {
        "type": "number",
        "description": "Port for the AICQ sidecar server (default: 6109).",
        "default": 6109,
        "minimum": 1024,
        "maximum": 65535
      },
      "autoStart": {
        "type": "boolean",
        "description": "Automatically start the sidecar server on gateway startup (default: true).",
        "default": true
      },
      "debug": {
        "type": "boolean",
        "description": "Enable verbose debug logging (default: false).",
        "default": false
      }
    }
  },
  "uiHints": {
    "enabled": {
      "label": "Enable AICQ",
      "help": "Toggle the AICQ encrypted chat plugin on or off."
    },
    "port": {
      "label": "Sidecar Port",
      "help": "The port the AICQ sidecar server listens on."
    },
    "autoStart": {
      "label": "Auto Start",
      "help": "Start the AICQ server automatically when OpenClaw gateway starts."
    },
    "debug": {
      "label": "Debug Mode",
      "help": "Enable verbose logging for troubleshooting.",
      "advanced": true
    }
  },
  "contracts": {
    "tools": [
      "chat-friend",
      "chat-send",
      "chat-export-key"
    ],
    "gateway": [
      "aicq.status",
      "aicq.friends.list",
      "aicq.friends.add",
      "aicq.friends.remove",
      "aicq.friends.requests",
      "aicq.friends.acceptRequest",
      "aicq.friends.rejectRequest",
      "aicq.sessions.list",
      "aicq.identity.info",
      "aicq.agent.create",
      "aicq.agent.delete",
      "aicq.chat.history",
      "aicq.chat.send",
      "aicq.chat.delete",
      "aicq.chat.streamChunk",
      "aicq.chat.streamEnd",
      "aicq.groups.list",
      "aicq.groups.create",
      "aicq.groups.join",
      "aicq.groups.messages",
      "aicq.groups.silent"
    ]
  },
  "sidecar": {
    "command": "node",
    "args": [
      "index.js"
    ],
    "port": 6109
  },
  "runtime": "node",
  "requires": {
    "node": ">=18.0.0",
    "packages": [
      "sql.js",
      "tweetnacl",
      "ws",
      "qrcode",
      "express"
    ]
  }
}
