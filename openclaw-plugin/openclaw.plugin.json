{
  "id": "aicq-chat",
  "name": "AICQ Encrypted Chat",
  "version": "2.1.0",
  "description": "End-to-end encrypted chat plugin for OpenClaw agents — Python/aiohttp implementation",
  "entry": "plugin.py",
  "tools": ["chat-friend", "chat-send", "chat-export-key"],
  "hooks": ["before_tool_call", "message_sending"],
  "gateway": [
    "aicq.status",
    "aicq.friends.list",
    "aicq.friends.add",
    "aicq.friends.remove",
    "aicq.friends.permissions",
    "aicq.friends.setPermissions",
    "aicq.friends.requests",
    "aicq.friends.acceptRequest",
    "aicq.friends.rejectRequest",
    "aicq.sessions.list",
    "aicq.identity.info",
    "aicq.agent.create",
    "aicq.agent.delete",
    "aicq.chat.streamChunk",
    "aicq.chat.streamEnd"
  ],
  "runtime": "python",
  "requires": {
    "python": ">=3.10",
    "packages": ["aiohttp>=3.9.0", "pynacl>=1.5.0", "aiosqlite>=0.19.0", "qrcode>=7.4", "packaging>=23.0"]
  }
}
