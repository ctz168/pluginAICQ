{
  "name": "aicq-chat-plugin",
  "version": "3.2.0",
  "description": "AICQ End-to-end Encrypted Chat Channel Plugin for OpenClaw — In-process Channel architecture with friend management, group chat, file transfer, and AI agent communication",
  "main": "index.js",
  "bin": {
    "aicq-plugin": "cli.js"
  },
  "files": [
    "index.js",
    "setup-entry.js",
    "cli.js",
    "postinstall.js",
    "src/",
    "lib/",
    "public/",
    "openclaw.plugin.json",
    "SKILL.md",
    "README.md"
  ],
  "scripts": {
    "start": "node index.js",
    "postinstall": "node postinstall.js",
    "install-deps": "npm install"
  },
  "keywords": [
    "aicq",
    "chat",
    "encrypted",
    "e2ee",
    "openclaw",
    "plugin",
    "channel",
    "ai-agent",
    "messaging",
    "p2p"
  ],
  "author": "ctz168",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ctz168/pluginAICQ.git",
    "directory": "openclaw-plugin"
  },
  "bugs": {
    "url": "https://github.com/ctz168/pluginAICQ/issues"
  },
  "homepage": "https://aicq.online",
  "dependencies": {
    "express": "^4.18.2",
    "marked": "^12.0.0",
    "multer": "^1.4.5-lts.1",
    "node-fetch": "^2.7.0",
    "qrcode": "^1.5.3",
    "sql.js": "^1.14.1",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1",
    "ws": "^8.16.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "openclaw": {
    "extensions": [
      "./index.js"
    ],
    "channel": {
      "id": "aicq-chat",
      "label": "AICQ Encrypted Chat",
      "blurb": "端到端加密即时通讯频道，基于 NaCl (X25519 + XSalsa20-Poly1305)",
      "icon": "🔐"
    },
    "compat": {
      "pluginApi": ">=2026.3.24-beta.2"
    }
  }
}
